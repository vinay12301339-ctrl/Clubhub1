{ "name": "clubhub-monorepo", "version": "1.0.0", "private": true, "description": "Clubhub - Full-stack club management platform", "scripts": { "dev": "pnpm -r --parallel run dev", "build": "pnpm -r run build", "start": "pnpm -r run start", "lint": "pnpm -r run lint", "db:migrate": "pnpm --filter @workspace/db run migrate", "db:seed": "pnpm --filter @workspace/db run seed", "api:dev": "pnpm --filter @workspace/api run dev", "web:dev": "pnpm --filter @workspace/web run dev" }, "workspaces": [ "apps/*", "packages/*" ] }